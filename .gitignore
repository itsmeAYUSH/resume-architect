# Root gitignore - Monorepo

# IDE
.vscode/
.idea/
*.sublime-workspace
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Git
.git/

# Dependencies and builds are ignored in each folder (client/, server/)
# See client/.gitignore and server/.gitignore for specific ignores

# Root node_modules (if using workspaces)
node_modules/

# Logs
logs/
*.log

# Temporary
.turbo/
.env.local
